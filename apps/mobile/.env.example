# Mobile env — all client-exposed values must be prefixed EXPO_PUBLIC_.
# Reuses the SAME Supabase project as apps/api (anon key is the public client key).

# Project Settings -> API in the Supabase dashboard (same values as apps/api's
# SUPABASE_URL / SUPABASE_ANON_KEY).
EXPO_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# Base URL of the tRPC API. Local dev points at apps/api (pnpm --filter
# @factfeed/api dev). Use your machine's LAN IP for a physical device;
# localhost works for the iOS simulator.
EXPO_PUBLIC_API_URL="http://localhost:3000"
